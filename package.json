{
  "name": "my-slides",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "slidev build presentations/cursor-ad/slides.md -o ../../dist --base /",
    "build:tutorial": "slidev build presentations/tutorial/slides.md -o ../../dist --base /",
    "build:cursor-ad": "slidev build presentations/cursor-ad/slides.md -o ../../dist --base /",
    "dev": "slidev slides.md --open",
    "dev:tutorial": "slidev presentations/tutorial/slides.md --open",
    "dev:cursor-ad": "slidev presentations/cursor-ad/slides.md --open",
    "export:tutorial": "slidev export presentations/tutorial/slides.md",
    "export:cursor-ad": "slidev export presentations/cursor-ad/slides.md"
  },
  "dependencies": {
    "@slidev/cli": "^52.14.1",
    "@slidev/theme-default": "latest",
    "@slidev/theme-seriph": "latest",
    "vue": "^3.5.29"
  }
}
